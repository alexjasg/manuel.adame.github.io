<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>Manuel Adame</title>
<link href="https://fonts.googleapis.com/css2?family=Big+Shoulders+Display:wght@700;900&family=Inter:wght@300;400;500&family=Share+Tech+Mono&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
html,body{min-height:100vh;background:#FAFAF8;color:#111;font-family:'Inter',system-ui,sans-serif;-webkit-font-smoothing:antialiased}
:root{
  --bg:#FAFAF8;--surface:#FFFFFF;--surface2:#F4F4F1;
  --ink:#111111;--ink2:#555555;--ink3:#AAAAAA;
  --line:#E8E8E4;--line2:#F0F0EC;
  --green:#1E6B45;--green-t:rgba(30,107,69,.1);
  --amber:#8A5C00;--amber-t:rgba(138,92,0,.1);
  --red:#B91C1C;--red-t:rgba(185,28,28,.08);
  --r:18px;--rm:12px;
}
.app{max-width:430px;margin:0 auto;padding-bottom:80px}
.hdr{padding:52px 28px 0}
.hdr-eye{font-size:9px;font-weight:500;letter-spacing:.24em;color:var(--ink3);text-transform:uppercase;margin-bottom:12px}
.hdr-title{font-family:'Big Shoulders Display',sans-serif;font-size:56px;font-weight:900;color:var(--ink);line-height:.9;letter-spacing:-.01em;text-transform:uppercase}
.rule{height:.5px;background:var(--line);margin:28px 28px 0}
.clock-section{padding:32px 28px 24px;display:flex;flex-direction:column;align-items:center}
.clock-tag{font-size:9px;font-weight:500;letter-spacing:.2em;color:var(--ink3);text-transform:uppercase;margin-bottom:18px}
.clock-digits{font-family:'Share Tech Mono',monospace;font-size:76px;font-weight:400;color:var(--ink);line-height:1;letter-spacing:.04em;font-variant-numeric:tabular-nums;transition:color .3s}
.clock-digits.late{color:var(--red)}
.clock-ampm{font-family:'Inter',sans-serif;font-size:15px;font-weight:300;color:var(--ink3);margin-left:10px;vertical-align:middle;letter-spacing:.06em}
.clock-date{font-size:11px;font-weight:300;color:var(--ink3);margin-top:12px;letter-spacing:.06em}
.prog-wrap{padding:0 28px 28px;display:flex;align-items:center;gap:14px}
.prog-track{flex:1;height:1px;background:var(--line);position:relative;overflow:visible}
.prog-fill{position:absolute;top:0;left:0;height:100%;background:var(--ink);transition:width .55s cubic-bezier(.4,0,.2,1)}
.prog-fill.mid{background:var(--amber)}
.prog-fill.low{background:var(--ink3)}
.prog-lbl{font-size:10px;font-weight:400;color:var(--ink3);white-space:nowrap;letter-spacing:.06em;font-variant-numeric:tabular-nums}
.toggle-wrap{padding:0 28px 32px}
.toggle-pill{display:flex;background:var(--surface2);border:0.5px solid var(--line);border-radius:50px;padding:3px;position:relative}
.toggle-thumb{position:absolute;top:3px;bottom:3px;width:calc(50% - 3px);background:var(--ink);border-radius:46px;transition:transform .3s cubic-bezier(.4,0,.2,1)}
.toggle-thumb.right{transform:translateX(calc(100%))}
.toggle-opt{flex:1;text-align:center;padding:11px 0;font-size:12px;font-weight:500;color:var(--ink3);border-radius:46px;cursor:pointer;transition:color .22s;position:relative;z-index:1;user-select:none;letter-spacing:.02em}
.toggle-opt.active{color:#fff}
.view{padding:0 28px 40px}
.view.hidden{display:none}
.sec-lbl{font-size:9px;font-weight:500;letter-spacing:.22em;color:var(--ink3);text-transform:uppercase;margin-bottom:16px;padding-left:1px;display:flex;align-items:center;gap:10px}
.sec-lbl::after{content:'';flex:1;height:.5px;background:var(--line)}
.act-list{display:flex;flex-direction:column;gap:8px}
.act-card{background:var(--surface);border:0.5px solid var(--line);border-radius:var(--r);overflow:hidden;transition:border-color .25s,box-shadow .25s}
.act-card.done{border-color:#AADBC0;box-shadow:0 0 0 3px rgba(30,107,69,.04)}
.act-card:active{transform:scale(.995)}
.act-row{display:flex;align-items:center;gap:14px;padding:16px 20px;cursor:pointer;transition:background .15s;user-select:none;-webkit-user-select:none}
.act-row:active{background:var(--surface2)}
.act-ico{width:36px;height:36px;border-radius:10px;background:var(--surface2);display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:background .25s}
.act-ico svg{width:17px;height:17px;stroke:var(--ink3);fill:none;stroke-width:1.5;stroke-linecap:round;stroke-linejoin:round;transition:stroke .25s}
.act-card.done .act-ico{background:#EAF4EE}
.act-card.done .act-ico svg{stroke:var(--green)}
.act-name{flex:1;font-size:14px;font-weight:400;color:var(--ink2);letter-spacing:.01em;transition:color .25s}
.act-card.done .act-name{color:var(--green)}
.act-right{display:flex;align-items:center;gap:10px;flex-shrink:0}
.act-pill{font-size:10px;font-weight:500;padding:3px 10px;border-radius:20px;transition:all .22s;white-space:nowrap;letter-spacing:.04em}
.pill-done{background:#EAF4EE;color:var(--green);border:0.5px solid #AADBC0}
.pill-pend{background:var(--surface2);color:var(--ink3);border:0.5px solid var(--line)}
.act-chev{width:14px;height:14px;flex-shrink:0;transition:transform .3s cubic-bezier(.4,0,.2,1)}
.act-chev svg{width:14px;height:14px;stroke:#D0D0D0;fill:none;stroke-width:1.5;stroke-linecap:round;stroke-linejoin:round}
.act-chev.open{transform:rotate(180deg)}
.act-body{max-height:0;overflow:hidden;transition:max-height .38s cubic-bezier(.4,0,.2,1)}
.act-body.open{max-height:580px}
.act-inner{padding:0 20px 20px;border-top:0.5px solid var(--line)}
.upl-zone{margin-top:16px;border:1px dashed var(--line);border-radius:var(--rm);padding:24px 16px;display:flex;flex-direction:column;align-items:center;gap:6px;cursor:pointer;transition:border-color .2s,background .2s;text-align:center}
.upl-zone:hover,.upl-zone:active{border-color:var(--ink3);background:var(--surface2)}
.upl-zone svg{width:18px;height:18px;stroke:var(--ink3);fill:none;stroke-width:1.5;stroke-linecap:round;stroke-linejoin:round}
.upl-t{font-size:12px;font-weight:500;color:var(--ink2)}
.upl-s{font-size:10px;font-weight:300;color:var(--ink3);letter-spacing:.04em}
.fi{display:none}
.thumbs{display:flex;gap:8px;flex-wrap:wrap;margin-top:12px}
.th-w{position:relative}
.th-img{width:68px;height:68px;border-radius:8px;object-fit:cover;border:0.5px solid var(--line);display:block}
.th-vid{width:68px;height:68px;border-radius:8px;border:0.5px solid var(--line);background:var(--surface2);display:flex;align-items:center;justify-content:center}
.th-vid svg{width:18px;height:18px;stroke:var(--ink3);fill:none;stroke-width:1.5;stroke-linecap:round;stroke-linejoin:round}
.th-del{position:absolute;top:-5px;right:-5px;width:20px;height:20px;border-radius:50%;background:var(--ink);border:1.5px solid var(--bg);cursor:pointer;display:flex;align-items:center;justify-content:center;transition:transform .15s}
.th-del:active{transform:scale(.88)}
.th-del svg{width:9px;height:9px;stroke:#fff;fill:none;stroke-width:2;stroke-linecap:round}
.upl-spin{font-size:10px;font-weight:300;color:var(--ink3);margin-top:8px;display:none;letter-spacing:.06em}
.upl-spin.on{display:block}
.act-note-ta{width:100%;margin-top:12px;padding:12px 14px;border:0.5px solid var(--line);border-radius:10px;font-size:13px;font-family:'Inter',inherit;font-weight:300;resize:none;min-height:56px;color:var(--ink);background:transparent;outline:none;transition:border-color .2s;line-height:1.55}
.act-note-ta:focus{border-color:#888}
.send-btn{display:none;width:100%;margin-top:12px;padding:14px;border-radius:50px;background:var(--ink);color:#fff;border:none;font-size:12px;font-weight:500;cursor:pointer;transition:opacity .2s,transform .15s;letter-spacing:.06em;text-transform:uppercase;align-items:center;justify-content:center;gap:8px}
.send-btn.on{display:flex}
.send-btn:hover{opacity:.82}
.send-btn:active{transform:scale(.97)}
.send-btn.sent{background:var(--green)}
.send-btn svg{width:13px;height:13px;stroke:#fff;fill:none;stroke-width:1.5;stroke-linecap:round;stroke-linejoin:round}
.daynote-card{background:var(--surface);border:0.5px solid var(--line);border-radius:var(--r);overflow:hidden}
.daynote-ta{width:100%;padding:18px 20px;border:none;font-size:13px;font-family:'Inter',inherit;font-weight:300;color:var(--ink);background:transparent;resize:none;min-height:96px;outline:none;line-height:1.65}
.daynote-ta::placeholder{color:var(--ink3)}
.daynote-foot{padding:12px 20px;border-top:0.5px solid var(--line);display:flex;justify-content:flex-end}
.daynote-btn{padding:10px 24px;border-radius:50px;background:var(--ink);color:#fff;border:none;font-size:11px;font-weight:500;cursor:pointer;transition:opacity .2s,transform .15s;letter-spacing:.08em;text-transform:uppercase}
.daynote-btn:active{transform:scale(.97)}
.daynote-btn.ok{background:var(--green)}
.cal-head-nav { display: flex; align-items: center; justify-content: space-between; margin-bottom: 20px; }
.cal-head { font-family:'Big Shoulders Display',sans-serif; font-size: 36px; font-weight: 900; color: var(--ink); letter-spacing: -.01em; text-transform: uppercase; margin-bottom: 0; }
.cal-nav-btn { background: none; border: none; cursor: pointer; color: var(--ink); padding: 8px; display: flex; align-items: center; justify-content: center; border-radius: 50%; transition: background .2s; }
.cal-nav-btn:hover { background: var(--surface2); }
.cal-card { background: var(--surface); border: 0.5px solid var(--line); border-radius: var(--r); padding: 20px; }
.cal-dow-row { display: grid; grid-template-columns: repeat(8, 1fr); gap: 5px; margin-bottom: 5px; }
.cal-week-row { display: grid; grid-template-columns: repeat(8, 1fr); gap: 5px; margin-bottom: 5px; }
.cal-dow { text-align: center; font-size: 9px; font-weight: 500; letter-spacing: .1em; color: var(--ink3); padding-bottom: 10px; text-transform: uppercase; }
.art-col { color: var(--ink3); display: flex; align-items: center; justify-content: center; padding-bottom: 10px; }
.cal-d { aspect-ratio: 1; border-radius: 9px; display: flex; align-items: center; justify-content: center; font-size: 12px; cursor: pointer; border: 0.5px solid transparent; transition: all .18s; font-variant-numeric: tabular-nums; color: var(--ink2); }
.cal-d:not(.emp):not(.fut):hover { border-color: var(--ink3); transform: scale(1.08); }
.cal-d:not(.emp):not(.fut):active { transform: scale(.95); }
.cal-d.today { border-color: var(--ink)!important; font-weight: 600; color: var(--ink)!important; }
.cal-d.green { background: #EAF4EE; color: var(--green); }
.cal-d.amber { background: #FDF4DC; color: var(--amber); }
.cal-d.red { background: #FEF2F1; color: var(--red); }
.cal-d.nodata { color: var(--line); }
.cal-d.fut { color: var(--line); cursor: default; }
.cal-d.emp { cursor: default; }
.cal-art-sum { font-size: 10px; font-weight: 600; color: var(--ink2); background: var(--surface2); border-radius: 8px; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 2px; font-variant-numeric: tabular-nums; aspect-ratio: 1; }
.cal-art-sum.zero { opacity: 0.3; }
.cal-legend { display: flex; gap: 14px; margin-top: 16px; flex-wrap: wrap; }
.leg { display: flex; align-items: center; gap: 6px; font-size: 10px; font-weight: 300; color: var(--ink3); letter-spacing: .04em; }
.leg-d { width: 7px; height: 7px; border-radius: 2px; }
.loader { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 80px 0; gap: 16px; }
.spin { width: 22px; height: 22px; border: 1px solid var(--line); border-top-color: var(--ink); border-radius: 50%; animation: sp .75s linear infinite; }
@keyframes sp { to { transform: rotate(360deg); } }
.load-t { font-size: 10px; font-weight: 300; color: var(--ink3); letter-spacing: .12em; text-transform: uppercase; }
.det-wrap { display: none; }
.det-wrap.on { display: block; }
.det-back { display: inline-flex; align-items: center; gap: 5px; font-size: 11px; font-weight: 300; color: var(--ink3); cursor: pointer; margin-bottom: 20px; padding: 4px 0; transition: color .18s; letter-spacing: .04em; }
.det-back:hover { color: var(--ink); }
.det-back svg { width: 14px; height: 14px; stroke: currentColor; fill: none; stroke-width: 1.5; stroke-linecap: round; stroke-linejoin: round; }
.det-date { font-family: 'Big Shoulders Display', sans-serif; font-size: 40px; font-weight: 900; color: var(--ink); text-transform: uppercase; letter-spacing: -.01em; margin-bottom: 4px; }
.det-sub { font-size: 11px; font-weight: 300; color: var(--ink3); margin-bottom: 20px; letter-spacing: .04em; }
.det-card { background: var(--surface); border: 0.5px solid var(--line); border-radius: var(--r); overflow: hidden; }
.det-row { display: flex; align-items: center; gap: 12px; padding: 13px 20px; border-bottom: 0.5px solid var(--line2); }
.det-row:last-child { border-bottom: none; }
.det-ico { width: 28px; height: 28px; border-radius: 8px; background: var(--surface2); display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.det-ico svg { width: 13px; height: 13px; stroke: var(--ink3); fill: none; stroke-width: 1.5; stroke-linecap: round; stroke-linejoin: round; }
.det-name { flex: 1; font-size: 12px; font-weight: 400; color: var(--ink2); letter-spacing: .01em; }
.det-pill { font-size: 10px; font-weight: 500; padding: 3px 10px; border-radius: 20px; letter-spacing: .04em; }
.det-pill.y { background: #EAF4EE; color: var(--green); border: 0.5px solid #AADBC0; }
.det-pill.n { background: var(--surface2); color: var(--ink3); border: 0.5px solid var(--line); }
.det-files { padding: 6px 20px 16px 60px; display: flex; flex-direction: column; gap: 4px; border-bottom: 0.5px solid var(--line2); }
.det-files:last-child { border-bottom: none; }
.det-a { font-size: 10px; font-weight: 300; color: var(--ink2); text-decoration: none; display: flex; align-items: center; gap: 4px; transition: color .15s; letter-spacing: .03em; }
.det-a:hover { color: var(--ink); }
.det-a svg { width: 10px; height: 10px; stroke: currentColor; fill: none; stroke-width: 1.5; stroke-linecap: round; stroke-linejoin: round; }
.det-note { margin-top: 14px; padding: 16px; background: var(--surface2); border-radius: var(--rm); font-size: 12px; font-weight: 300; color: var(--ink2); line-height: 1.7; letter-spacing: .02em; }
.toast { position: fixed; bottom: 32px; left: 50%; transform: translateX(-50%) translateY(12px); background: var(--ink); color: #fff; padding: 11px 24px; border-radius: 50px; font-size: 11px; font-weight: 500; opacity: 0; transition: all .28s cubic-bezier(.4,0,.2,1); pointer-events: none; white-space: nowrap; z-index: 999; letter-spacing: .06em; text-transform: uppercase; }
.toast.on { opacity: 1; transform: translateX(-50%) translateY(0); }
.toast.err { background: var(--red); }
.det-thumb-grid { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 6px; }
.det-thumb-wrap { width: 52px; height: 52px; border-radius: 8px; overflow: hidden; border: 0.5px solid var(--line); display: block; flex-shrink: 0; position: relative; }
.det-thumb-wrap img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform .2s; }
.det-thumb-wrap:hover img { transform: scale(1.08); }
</style>
</head>
