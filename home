function ic(k,w=17,h=17){return`<svg width="${w}" height="${h}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">${P[k]}</svg>`}
function todayMX(){return new Date().toLocaleDateString('en-CA',{timeZone:'America/Mexico_City'})}
const TODAY = todayMX();
let aD = {};
let calD = {};
let sending = {};
const dateNow = new Date(new Date().toLocaleString('en-US',{timeZone:'America/Mexico_City'}));
let navYear = dateNow.getFullYear();
let navMonth = dateNow.getMonth();
function slugAct(id){
  const a = ACTS.find(x=>x.id===id);
  if(!a) return id;
  return a.name.toLowerCase()
    .normalize('NFD').replace(/[\u0300-\u036f]/g,'')
    .replace(/\s+/g,'_');
}
function progSnapshot(){
  const done = ACTS.filter(a=>aD[a.id]?.done).length;
  return {
    progreso_completadas: done,
    progreso_total: ACTS.length,
    progreso_porcentaje: Math.round(done/ACTS.length*100)
  };
}

// ── PETICIÓN POST SIN PREFLIGHT CORS ────────────────────
// Usar text/plain en vez de application/json evita el OPTIONS preflight.
// n8n recibe el JSON como string y lo parsea igual en $json.body
async function postNoCors(url, payload){
  const rs = await fetch(url, {
    method: 'POST',
    headers: { 'Content-Type': 'text/plain;charset=UTF-8' },
    body: JSON.stringify(payload)
  });
  if(!rs.ok) throw new Error('HTTP '+rs.status);
  return rs;
}

async function dispatch(accion, extra={}){
  const payload = {
    accion,
    fecha: TODAY,
    ...progSnapshot(),
    ...extra
  };
  return postNoCors(WH_SAVE, payload);
}

function toast(msg,err=false){
  const t=document.getElementById('toast');
  t.textContent=msg; t.className='toast on'+(err?' err':'');
  setTimeout(()=>{t.className='toast'},2800);
}
function tick(){
  const n=new Date(new Date().toLocaleString('en-US',{timeZone:'America/Mexico_City'}));
  let h=n.getHours();
  const m=String(n.getMinutes()).padStart(2,'0');
  const s=String(n.getSeconds()).padStart(2,'0');
  const ap=h>=12?'PM':'AM'; h=h%12||12;
  const el=document.getElementById('clk');
  el.childNodes[0].nodeValue=`${String(h).padStart(2,'0')}:${m}:${s}`;
  document.getElementById('clk-ap').textContent=ap;
  el.className='clock-digits'+(n.getHours()>=20?' late':'');
}
function setDate(){
  const n=new Date(new Date().toLocaleString('en-US',{timeZone:'America/Mexico_City'}));
  const days=['Domingo','Lunes','Martes','Miércoles','Jueves','Viernes','Sábado'];
  const months=['enero','febrero','marzo','abril','mayo','junio','julio','agosto','septiembre','octubre','noviembre','diciembre'];
  document.getElementById('clk-date').textContent=`${days[n.getDay()]} ${n.getDate()} de ${months[n.getMonth()]}`;
}
setInterval(tick,1000); tick(); setDate();
function updProg(){
  const {progreso_completadas:done, progreso_total:total, progreso_porcentaje:pct} = progSnapshot();
  const fill=document.getElementById('prog-fill');
  fill.style.width=pct+'%';
  fill.className='prog-fill'+(pct===100?'':pct>=50?' mid':' low');
  document.getElementById('prog-lbl').textContent=`${done} · ${total}`;
}
function sw(v){
  const h=v==='his';
  document.getElementById('o-sub').className='toggle-opt'+(h?'':' active');
  document.getElementById('o-his').className='toggle-opt'+(h?' active':'');
  document.getElementById('t-thumb').className='toggle-thumb'+(h?' right':'');
  document.getElementById('v-sub').className='view'+(h?' hidden':'');
  document.getElementById('v-his').className='view'+(h?'':' hidden');
  if(h) {
    navYear = parseInt(TODAY.split('-')[0]);
    navMonth = parseInt(TODAY.split('-')[1]) - 1;
    loadCal();
  }
}
function buildActs(){
  const list=document.getElementById('act-list');
  list.innerHTML='';
  ACTS.forEach(a=>{
    const d=aD[a.id]||{done:false,files:[],note:''};
    const el=document.createElement('div');
    el.className='act-card'+(d.done?' done':'');
    el.id='ac-'+a.id;
    el.innerHTML=`
      <div class="act-row" onclick="tog('${a.id}')">
        <div class="act-ico">${ic(a.icon)}</div>
        <div class="act-name">${a.name}</div>
        <div class="act-right">
          <span class="act-pill ${d.done?'pill-done':'pill-pend'}" id="pill-${a.id}">${d.done?'Listo':'Pendiente'}</span>
          <div class="act-chev" id="chev-${a.id}">${ic('chevdown',14,14)}</div>
        </div>
      </div>
      <div class="act-body" id="body-${a.id}">
        <div class="act-inner">
          <div class="upl-zone" onclick="document.getElementById('fi-${a.id}').click()">
            ${ic('upload',18,18)}
            <div class="upl-t">Subir evidencia</div>
            <div class="upl-s">Solo fotos (máx. 3)</div>
          </div>
          <input type="file" class="fi" id="fi-${a.id}" accept="image/*" multiple onchange="onFiles('${a.id}',this)">
          <div class="upl-spin" id="sp-${a.id}">Preparando archivos...</div>
          <div class="thumbs" id="th-${a.id}"></div>
          <textarea class="act-note-ta" id="n-${a.id}" placeholder="Nota de la actividad..." rows="2" onblur="pN('${a.id}')">${d.note||''}</textarea>
          <button class="send-btn${d.done?' on':''}" id="sb-${a.id}" onclick="sendAct('${a.id}')">
            ${ic('send',13,13)} Enviar registro
          </button>
        </div>
      </div>`;
    list.appendChild(el);
    rTh(a.id, d.files||[]);
  });
  updProg();
}
function tog(id){
  const b=document.getElementById('body-'+id);
  const c=document.getElementById('chev-'+id);
  const open=b.classList.contains('open');
  document.querySelectorAll('.act-body.open').forEach(x=>x.classList.remove('open'));
  document.querySelectorAll('.act-chev.open').forEach(x=>x.classList.remove('open'));
  if(!open){b.classList.add('open');c.classList.add('open');}
}
function rTh(id,files){
  const c=document.getElementById('th-'+id);
  if(!c) return;
  c.innerHTML='';
  (files||[]).forEach((f,i)=>{
    const w=document.createElement('div');
    w.className='th-w';
    w.innerHTML=`<img class="th-img" src="${f.url}" alt=""><button class="th-del" onclick="rmF('${id}',${i})" aria-label="Eliminar">${ic('close',9,9)}</button>`;
    c.appendChild(w);
  });
}
function rmF(id,i){
  if(!aD[id]) return;
  aD[id].files.splice(i,1);
  if(!aD[id].files.length){
    aD[id].done=false;
    document.getElementById('ac-'+id).className='act-card';
    document.getElementById('pill-'+id).className='act-pill pill-pend';
    document.getElementById('pill-'+id).textContent='Pendiente';
    document.getElementById('sb-'+id).className='send-btn';
  }
  rTh(id,aD[id].files);
  updProg();
}
async function compressImage(file) {
  return new Promise((resolve) => {
    const reader = new FileReader();
    reader.onload = (e) => {
      const img = new Image();
      img.onload = () => {
        let w = img.width;
        let h = img.height;
        const max = 1200;
        if (w > max || h > max) {
          if (w > h) { h = Math.round((h * max) / w); w = max; }
          else { w = Math.round((w * max) / h); h = max; }
        }
        const cvs = document.createElement('canvas');
        cvs.width = w; cvs.height = h;
        const ctx = cvs.getContext('2d');
        ctx.drawImage(img, 0, 0, w, h);
        resolve(cvs.toDataURL('image/jpeg', 0.65));
      };
      img.src = e.target.result;
    };
    reader.readAsDataURL(file);
  });
}
async function onFiles(id,input){
  if(!aD[id]) aD[id]={done:false,files:[],note:''};
  const cur=aD[id].files.length;
  const slots=3-cur;
  if(slots<=0){toast('Máximo 3 archivos',true);return;}
  const picked=Array.from(input.files).slice(0,slots);
  document.getElementById('sp-'+id).className='upl-spin on';
  for(const f of picked){
    if(!f.type.startsWith('image/')) {
      toast('Solo se permiten imágenes', true);
      continue;
    }
    const b64 = await compressImage(f);
    aD[id].files.push({url:b64, type:'image/jpeg', name:f.name});
  }
  aD[id].done=true;
  document.getElementById('ac-'+id).className='act-card done';
  document.getElementById('pill-'+id).className='act-pill pill-done';
  document.getElementById('pill-'+id).textContent='Listo';
  document.getElementById('sb-'+id).className='send-btn on';
  document.getElementById('sp-'+id).className='upl-spin';
  rTh(id,aD[id].files);
  updProg();
  input.value='';
}
function pN(id){
  if(!aD[id]) aD[id]={done:false,files:[],note:''};
  aD[id].note=document.getElementById('n-'+id)?.value||'';
}
async function sendAct(id){
  if(sending[id]) return;
  sending[id]=true;
  pN(id);
  const btn=document.getElementById('sb-'+id);
  const orig=btn.innerHTML;
  btn.innerHTML=ic('check',13,13)+' Enviando...';
  btn.className='send-btn on';
  btn.disabled=true;
  const archivos = (aD[id].files||[]).map(f=>({
    url:   f.url,
    type:  f.type,
    name:  f.name
  }));
  try{
    await dispatch('guardar_actividad',{
      tipo_de_actividad: slugAct(id),
      nota:              aD[id].note||'',
      archivos,
      cantidad_archivos: archivos.length,
      tipos_archivos:    archivos.map(f=>f.type)
    });
    btn.innerHTML=ic('check',13,13)+' Enviado';
    btn.className='send-btn on sent';
    toast('Registro enviado');
  } catch(e){
    console.error('Error enviando:', e);
    btn.innerHTML=orig;
    btn.className='send-btn on';
    toast('Error al enviar', true);
  } finally {
    btn.disabled=false;
    setTimeout(()=>{
      btn.innerHTML=ic('send',13,13)+' Enviar registro';
      btn.className='send-btn on';
      sending[id]=false;
    },2800);
  }
}
async function saveNote(){
  if(sending['nota']) return;
  sending['nota']=true;
  const btn=document.getElementById('note-btn');
  btn.textContent='Guardando...';
  btn.disabled=true;
  try{
    await dispatch('guardar_nota_diaria',{
      tipo_de_actividad: 'nota_del_dia',
      nota: document.getElementById('day-note').value
    });
    btn.className='daynote-btn ok';
    btn.textContent='Guardado';
    toast('Nota guardada');
  } catch(e){
    console.error('Error guardando nota:', e);
    toast('Error al guardar', true);
  } finally {
    btn.disabled=false;
    setTimeout(()=>{
      btn.className='daynote-btn';
      btn.textContent='Guardar';
      sending['nota']=false;
    },2000);
  }
}
function chMonth(dir) {
  navMonth += dir;
  if(navMonth > 11) { navMonth = 0; navYear++; }
  else if(navMonth < 0) { navMonth = 11; navYear--; }
  loadCal();
}
async function loadCal(){
  document.getElementById('ld').style.display='flex';
  document.getElementById('cal-sec').style.display='none';
  document.getElementById('det').className='det-wrap';
  const ms = String(navMonth + 1).padStart(2, '0');
  const mesStr = `${navYear}-${ms}`;
  try{
    console.log("Consultando historial para:", mesStr);
    const rs = await postNoCors(WH_GET, {
      accion: 'consultar_calendario',
      mes: mesStr
    });
    const j = await rs.json();
    calD = j.data || j || {};
    console.log("Datos recibidos:", calD);
  } catch(e){
    console.error('Error consultando historial:', e);
    toast('Error al consultar historial', true);
    calD = {};
  }
  document.getElementById('ld').style.display='none';
  document.getElementById('cal-sec').style.display='block';
  renderCal();
}
function renderCal(){
  const mNames = ['Enero','Febrero','Marzo','Abril','Mayo','Junio','Julio','Agosto','Septiembre','Octubre','Noviembre','Diciembre'];
  document.getElementById('cal-month-lbl').textContent = `${mNames[navMonth]} ${navYear}`;
  const g = document.getElementById('cal-g');
  g.innerHTML = '';
  const first = new Date(navYear, navMonth, 1).getDay();
  const totalDays = new Date(navYear, navMonth + 1, 0).getDate();
  const currentMonthStr = `${navYear}-${String(navMonth+1).padStart(2,'0')}`;
  const isCurMonth = TODAY.startsWith(currentMonthStr);
  const td = parseInt(TODAY.split('-')[2]);
  let daysArr = [];
  for(let i=0; i<first; i++) daysArr.push(null);
  for(let d=1; d<=totalDays; d++) daysArr.push(d);
  while(daysArr.length % 7 !== 0) daysArr.push(null);
  const weeks = daysArr.length / 7;
  for(let w=0; w<weeks; w++) {
    const row = document.createElement('div');
    row.className = 'cal-week-row';
    let weekArtists = 0;
    for(let i=0; i<7; i++) {
      const d = daysArr[w*7 + i];
      const el = document.createElement('div');
      if(!d) {
        el.className = 'cal-d emp';
      } else {
        const ds = `${currentMonthStr}-${String(d).padStart(2,'0')}`;
        const info = calD[ds];
        const isT = isCurMonth && d === td;
        const isFut = ds > TODAY;
        let cls = 'cal-d';
        if (isFut) {
          cls += ' fut';
        } else if (info && info.progreso_completadas !== undefined) {
          const p = info.progreso_completadas;
          if (p >= 10) cls += ' green';
          else if (p >= 6 && p <= 9) cls += ' amber';
          else if (p >= 1 && p <= 5) cls += ' red';
          else cls += ' nodata';
        } else {
          cls += ' nodata';
        }
        if (isT) cls += ' today';
        el.className = cls;
        el.textContent = d;
        if (!isFut) {
          el.onclick = () => openDet(ds, info);
        }
        if (info && info.cantidad_artistas) {
          weekArtists += parseInt(info.cantidad_artistas) || 0;
        }
      }
      row.appendChild(el);
    }
    const artEl = document.createElement('div');
    artEl.className = 'cal-art-sum' + (weekArtists === 0 ? ' zero' : '');
    artEl.innerHTML = `${ic('artist', 11, 11)} <span>${weekArtists}</span>`;
    row.appendChild(artEl);
    g.appendChild(row);
  }
}
function openDet(ds, info){
  document.getElementById('cal-sec').style.display='none';
  const mNames = ['Ene','Feb','Mar','Abr','May','Jun','Jul','Ago','Sep','Oct','Nov','Dic'];
  const [,mo,d] = ds.split('-');
  const lbl = `${parseInt(d)} ${mNames[parseInt(mo)-1]}`;
  let html = `<div class="det-back" onclick="closeDet()">${ic('back',14,14)} Volver</div>`;
  html += `<div class="det-date">${lbl}</div>`;
  if (info) {
    const pComp = info.progreso_completadas || 0;
    const pTot = info.progreso_total || 10;
    const pPct = Math.round((pComp/pTot)*100) || 0;
    html += `<div class="det-sub">${pPct}% completado · ${pComp} de ${pTot}</div>`;
    html += `<div class="det-card">`;
    ACTS.forEach(a => {
      const ad = info.actividades?.[a.id];
      const done = ad?.done;
      html += `<div class="det-row"><div class="det-ico">${ic(a.icon,13,13)}</div><div class="det-name">${a.name}</div><span class="det-pill ${done?'y':'n'}">${done?'Completo':'—'}</span></div>`;
      if (done && ad.archivos && ad.archivos.length) {
        html += `<div class="det-files"><div class="det-thumb-grid">`;
        ad.archivos.forEach(f => {
          if (f.thumbnail && f.driveLink) {
            html += `<a href="${f.driveLink}" target="_blank" class="det-thumb-wrap">
                       <img src="${f.thumbnail}" alt="Evidencia">
                     </a>`;
          } else if (f.url) {
             html += `<a href="${f.url}" target="_blank" class="det-a">${ic('link',10,10)}${f.name||'Ver archivo'}</a>`;
          }
        });
        html += `</div></div>`;
      }
    });
    html += `</div>`;
    if (info.nota) html += `<div class="det-note">${info.nota}</div>`;
  } else {
    html += `<div class="det-sub" style="padding:28px 0;text-align:center">Sin registro para este día.</div>`;
  }
  const det = document.getElementById('det');
  det.innerHTML = html;
  det.className = 'det-wrap on';
}
function closeDet(){
  document.getElementById('det').className='det-wrap';
  document.getElementById('cal-sec').style.display='block';
}
buildActs();
</script>
